# Base de datos
# Con Docker Compose, estas variables las usa el servicio "db" y la cadena de
# conexión de abajo es la que utiliza la aplicación para conectarse.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tickets
DATABASE_URL=postgresql://postgres:postgres@db:5432/tickets

# Proveedor LLM (compatible con OpenAI)
# Necesaria para la clasificación con IA. Sin ella los tickets se crean igual,
# pero quedan como "Pendiente" hasta que se configure una clave.
OPENAI_API_KEY=sk-tu-clave-aqui
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
